<view class="game-page">
  <view class="hud">
    <view class="hud-item">
      <text class="hud-label">生命</text>
      <text class="hud-value">{{life}}</text>
    </view>
    <view class="hud-item">
      <text class="hud-label">金币</text>
      <text class="hud-value">{{gold}}</text>
    </view>
    <view class="hud-item">
      <text class="hud-label">波次</text>
      <text class="hud-value">{{wave}}</text>
    </view>
  </view>

  <view class="canvas-section">
    <canvas
      id="gameCanvas"
      type="2d"
      canvas-id="gameCanvas"
      class="game-canvas"
    ></canvas>
  </view>

  <view class="tower-actions">
    <button class="tower-button">普通塔</button>
    <button class="tower-button tower-button-fast">快速塔</button>
  </view>
</view>
