.game-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 32rpx 24rpx 40rpx;
  background: #f3f4f6;
  box-sizing: border-box;
  gap: 24rpx;
}

.hud {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.hud-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 20rpx 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.08);
}

.hud-label {
  font-size: 24rpx;
  color: #6b7280;
}

.hud-value {
  margin-top: 12rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
}

.canvas-section {
  flex: 1;
  min-height: 0;
  display: flex;
}

.game-canvas {
  width: 100%;
  height: 100%;
  min-height: 720rpx;
  background: #dbeafe;
  border: 4rpx solid #93c5fd;
  border-radius: 24rpx;
  box-sizing: border-box;
}

.tower-actions {
  display: flex;
  gap: 20rpx;
}

.tower-button {
  flex: 1;
  margin: 0;
  border-radius: 20rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}

.tower-button-fast {
  background: #059669;
}
